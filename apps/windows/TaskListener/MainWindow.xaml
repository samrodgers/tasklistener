<Window
    x:Class="TaskListener.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="14" RowDefinitions="Auto,Auto,*,Auto" RowSpacing="10">
        <TextBlock Grid.Row="0" Text="TaskListener" FontSize="18" FontWeight="SemiBold"/>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox x:Name="DraftBox" PlaceholderText="Add a task" KeyDown="DraftBox_KeyDown"/>
            <Button Grid.Column="1" Content="Add" Click="AddClick"/>
        </Grid>
        <ListView x:Name="TaskList" Grid.Row="2" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:TaskItem" xmlns:local="using:TaskListener">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,4">
                        <CheckBox Grid.Column="0" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Bind Text}" />
                            <TextBlock Text="{x:Bind DueHint}" Opacity="0.6" FontSize="11" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <TextBlock Grid.Row="3" x:Name="FooterStatus" Opacity="0.6" FontSize="11"/>
    </Grid>
</Window>
